precondition = ["Platform"]
callsign = "org.rdk.Account"
autostart = "false"
startuporder = "@PLUGIN_ACCOUNT_STARTUPORDER@"

configuration = JSON()
rootobject = JSON()

rootobject.add("mode", "@PLUGIN_ACCOUNT_MODE@")
rootobject.add("locator", "lib@PLUGIN_IMPLEMENTATION@.so")

configuration.add("root", rootobject)
